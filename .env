# IBM watsonx.ai Configuration
# Copy this file to .env and fill in your real credentials — never commit .env
IBM_API_KEY=c4WZELxOO4lFEHRBMteQAKlPypwlQwbPHyM8xKjIHPwI
IBM_PROJECT_ID=32e7909c-6a65-4be4-b345-67e1273c330b
# Set IBM_URL to the regional endpoint that matches your IBM Cloud watsonx.ai resource.
# Sydney (au-syd):  https://au-syd.ml.cloud.ibm.com
# Dallas (us-south): https://us-south.ml.cloud.ibm.com
# Frankfurt (eu-de): https://eu-de.ml.cloud.ibm.com
# Tokyo (jp-tok):    https://jp-tok.ml.cloud.ibm.com
# London (eu-gb):    https://eu-gb.ml.cloud.ibm.com
IBM_URL=https://au-syd.ml.cloud.ibm.com
# Leave MODEL_NAME empty to auto-discover the best available text model,
# or set it to a model ID exactly as returned by the watsonx model-spec API.
# Do NOT include "instance_id=openshift" — that is for on-premises CPD only.
MODEL_NAME=

# Flask Configuration
FLASK_SECRET_KEY=your_super_secret_flask_key_here
FLASK_ENV=development
FLASK_DEBUG=True

# Application Configuration
APP_NAME=AgriGuide AI
APP_VERSION=1.0.0